rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /volani/{id} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['stul','status','ts'])
                    && request.resource.data.stul is string
                    && request.resource.data.status == 'active';
      allow read, update, delete: if request.auth != null
                    && request.auth.token.firebase.sign_in_provider == 'password';
    }

    match /objednavky/{id} {
      allow create: if request.auth != null
                    && request.resource.data.keys().hasOnly(['stul','polozky','status','ts','createdBy','poznamka'])
                    && request.resource.data.stul is string
                    && request.resource.data.status == 'active'
                    && request.resource.data.polozky is list
                    && request.resource.data.polozky.size() > 0
                    && request.resource.data.polozky.size() <= 50
                    && request.resource.data.createdBy == request.auth.uid
                    && (!('poznamka' in request.resource.data)
                        || (request.resource.data.poznamka is string
                            && request.resource.data.poznamka.size() <= 300));
      allow read: if request.auth != null
                  && (request.auth.token.firebase.sign_in_provider == 'password'
                      || resource.data.createdBy == request.auth.uid);
      allow delete: if request.auth != null
                    && (request.auth.token.firebase.sign_in_provider == 'password'
                        || (resource.data.createdBy == request.auth.uid
                            && resource.data.status == 'active'));
      allow update: if request.auth != null
                    && request.auth.token.firebase.sign_in_provider == 'password';
    }

    match /{document=**} {
      allow read, write: if request.auth != null
                    && request.auth.token.firebase.sign_in_provider == 'password';
    }
  }
}
